# Copy to terraform.tfvars and fill in.
aws_region = "us-east-1"

# VPC to deploy into (required). Provide here or via TF_VAR_vpc_id.
# vpc_id = "vpc-0123456789abcdef0"
# Optionally pin specific subnets (must have outbound internet). Defaults to all
# subnets in the VPC if omitted:
# subnet_ids = ["subnet-aaa", "subnet-bbb"]

# Datadog site. Defaults to US5; override if your org is on another site:
# dd_site = "datadoghq.com"

# Provide the API key via the environment instead of committing it:
#   export TF_VAR_dd_api_key=...

# --- Oodle dual-write (optional) ---
# Also forward Agent metrics/logs/traces to Oodle. Get these from:
#   oodle integrations list -o json   (collector domains + instance ID)
#   oodle api-keys list -o json       (ingestion API key)
# oodle_dual_write            = true
# oodle_instance_id           = "inst-xxxxxxxx"
# oodle_collector_domain      = "inst-xxxxxxxx.collector.oodle.ai"
# oodle_logs_collector_domain = "inst-xxxxxxxx-logs.collector.oodle.ai"
# Provide the Oodle API key via the environment:
#   export TF_VAR_oodle_api_key=...
