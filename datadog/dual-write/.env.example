# Datadog Configuration
# Get your API key from: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your-datadog-api-key

# Datadog site (default: datadoghq.com)
DD_SITE=datadoghq.com

# Oodle Configuration (dual-write)
# Get these from: oodle integrations list -o json
OODLE_API_KEY=your-oodle-api-key
OODLE_COLLECTOR_DOMAIN=your-instance.collector.oodle.ai
OODLE_LOGS_COLLECTOR_DOMAIN=your-instance-logs.collector.oodle.ai
OODLE_INSTANCE_ID=your-instance-id
