# Datadog Configuration
# Get your API key from: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your-datadog-api-key
DD_SITE=datadoghq.com

# Oodle Configuration
# Get these values from your Oodle UI: Settings -> API Keys
OODLE_API_KEY=your-oodle-api-key
OODLE_INSTANCE=your-instance-id

# Load Generator (optional)
# Duration in seconds (default: 3600 = 1 hour)
LOAD_DURATION=86400
# Interval between requests in seconds (default: 3)
LOAD_INTERVAL=3
