# Oodle Configuration
# Get these from: https://<deployment>.oodle.ai/settings?integration=DB_MONITORING
# Where <deployment> is your Oodle deployment (e.g. us1, ap1)
OODLE_API_KEY=your-oodle-api-key
DD_DD_URL=https://your-instance.collector.oodle.ai/v1/datadog/your-instance
DD_DATABASE_MONITORING_SAMPLES_LOGS_DD_URL=https://your-instance-logs.collector.oodle.ai
DD_DATABASE_MONITORING_ACTIVITY_LOGS_DD_URL=https://your-instance-logs.collector.oodle.ai
DD_DATABASE_MONITORING_METRICS_LOGS_DD_URL=https://your-instance.collector.oodle.ai

# PostgreSQL Configuration
POSTGRES_PASSWORD=postgres
DBM_MONITORING_PASSWORD=datadog
