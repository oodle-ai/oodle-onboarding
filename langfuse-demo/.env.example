# Oodle Configuration
# Get these values from your Oodle UI: Settings -> API Keys
OODLE_INSTANCE=your-instance-id
OODLE_API_KEY=your-api-key

# Google Gemini Configuration
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional: override the default model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
# Optional: override the default model (default: gpt-4o-mini)
OPENAI_MODEL=o3-mini
# Optional: point at an OpenAI-compatible endpoint (e.g. Gemini)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: distinct service names per export path
# LANGFUSE_SERVICE_NAME=langfuse-demo
# OTEL_SERVICE_NAME=langfuse-demo-otel

# Langfuse Configuration
# For Langfuse Cloud: get keys from https://cloud.langfuse.com -> Settings -> API Keys
# For self-hosted: these are auto-created by LANGFUSE_INIT_* vars in docker-compose.yml
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# Cloud: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US)
# Self-hosted: http://langfuse-web:3000 (internal Docker network; UI is at http://localhost:3060)
LANGFUSE_BASE_URL=http://langfuse-web:3000
