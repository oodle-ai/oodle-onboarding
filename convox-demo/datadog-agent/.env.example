# Copy to .env and fill in. The API key determines the DD_SITE (org region).
# Get an API key: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your-datadog-api-key
DD_SITE=us5.datadoghq.com

# --- Dual-write to Oodle (metrics + traces) ---
# From your Oodle Datadog integration (oodle integrations get-setup-spec datadog).
OODLE_API_KEY=your-oodle-api-key
OODLE_COLLECTOR_DOMAIN=inst-xxxx.collector.oodle.ai
OODLE_INSTANCE_ID=inst-xxxx
