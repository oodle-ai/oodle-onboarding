# Copy to .env and fill in.
#
# Single-shipping to Oodle ONLY (metrics + traces): the DD Agent sends to Oodle and
# nothing to Datadog, so only the Oodle credentials below are required. The Oodle API key
# is used as DD_API_KEY (Makefile), and the collector domain/instance build the intake URLs.
# From your Oodle Datadog integration tile (oodle integrations get-setup-spec datadog).
OODLE_API_KEY=your-oodle-api-key
OODLE_COLLECTOR_DOMAIN=inst-xxxx.collector.oodle.ai
OODLE_INSTANCE_ID=inst-xxxx
