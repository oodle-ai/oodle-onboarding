# Oodle credentials for the log agent (set via `convox env set`, never committed).
# Copy to .env and fill in. Values come from your `oodle configure` setup.

# Oodle instance ID — also the subdomain prefix of the collector host.
OODLE_INSTANCE=inst-xxxxxxxx

# Oodle API key.
OODLE_API_KEY=your-oodle-api-key

# CloudWatch log group the collector writes the (raw-format) copy to. Set this to the app's
# original Convox awslogs group name so downstream tooling is unchanged, e.g.
# gm-test-rails-demo-LogGroup-jlgTakaSC8UE. This group is owned by the collector, not Convox,
# so it survives LogDriver toggles.
CW_LOG_GROUP=gm-test-rails-demo-LogGroup-xxxxxxxxxxxx

# Convox deploy target (used by the Makefile).
RACK=org-team-i4e/gm-test
APP=oodle-log-agent
