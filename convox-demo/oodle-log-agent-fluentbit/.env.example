# Oodle credentials + rack for the Fluent Bit log agent (set via `convox env set`, never committed).
# Copy to .env and fill in. Values come from your `oodle configure` setup.

# Oodle instance ID — also the subdomain prefix of the collector host.
OODLE_INSTANCE=inst-xxxxxxxx

# Oodle API key.
OODLE_API_KEY=your-oodle-api-key

# Short rack name that prefixes ECS task families (used to derive a clean app name). NOT the
# org/rack deploy target — just the rack, e.g. gm-test.
RACK_PREFIX=gm-test

# Convox deploy target (used by the Makefile).
RACK=org-team-i4e/gm-test
APP=oodle-log-agent-fb
