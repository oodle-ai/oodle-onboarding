{
  "displayName": "oodle-test-promql-cpu",
  "documentation": {
    "content": "Average CPU utilization rate exceeded 70% (PromQL)",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "PromQL CPU > 70%",
      "conditionPrometheusQueryLanguage": {
        "query": "avg(up) < 1",
        "duration": "300s",
        "evaluationInterval": "60s"
      }
    }
  ],
  "combiner": "OR",
  "enabled": true
}
