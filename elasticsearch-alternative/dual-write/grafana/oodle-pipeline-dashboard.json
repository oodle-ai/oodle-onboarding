          "expr": "sum(increase(fluentbit_output_dropped_records_total{agent=\"$agent\"}[$__range])) OR sum(increase(vector_component_discarded_events_total{agent=\"$agent\"}[$__range])) OR sum(increase(otelcol_exporter_send_failed_log_records{agent=\"$agent\"}[$__range])) OR sum(increase(logstash_stats_pipeline_plugin_documents_non_retryable_failures{agent=\"$agent\"}[$__range])) + sum(increase(logstash_stats_pipeline_dead_letter_queue_dropped_events{agent=\"$agent\"}[$__range]))",
