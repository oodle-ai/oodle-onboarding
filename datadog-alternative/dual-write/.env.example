# Datadog Configuration
# Your existing Datadog API key
DD_API_KEY=your-datadog-api-key
DD_SITE=datadoghq.com

# Oodle Configuration (for dual-write)
# Get these values from your Oodle UI: Settings -> Integrations -> Datadog
OODLE_ENDPOINT=https://your-oodle-endpoint
OODLE_API_KEY=your-oodle-api-key
